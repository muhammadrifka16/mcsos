PASS_COUNT=0
FAIL_COUNT=0
for idx in "${!RESULT_NUM[@]}"; do
  num="${RESULT_NUM[$idx]}"
  title="${RESULT_TITLE[$idx]}"
  status="${RESULT_STATUS[$idx]}"
  if [ "$status" = "PASS" ]; then
    PASS_COUNT=$((PASS_COUNT+1))
    printf "${BOLD}${GOLD_BRIGHT}‚Ēā${RESET} %-4s ${BOLD}${GOLD_BRIGHT}‚Ēā${RESET} %-32s ${BOLD}${GOLD_BRIGHT}‚Ēā${RESET} ${GREEN}%-10s${RESET} ${BOLD}${GOLD_BRIGHT}‚Ēā${RESET}\n" "$num" "${title:0:32}" "‚úĒ PASS"
  else
    FAIL_COUNT=$((FAIL_COUNT+1))
    printf "${BOLD}${GOLD_BRIGHT}‚Ēā${RESET} %-4s ${BOLD}${GOLD_BRIGHT}‚Ēā${RESET} %-32s ${BOLD}${GOLD_BRIGHT}‚Ēā${RESET} ${RED}%-10s${RESET} ${BOLD}${GOLD_BRIGHT}‚Ēā${RESET}\n" "$num" "${title:0:32}" "‚úė FAIL"
  fi
done
